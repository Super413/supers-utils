class Item {
    constructor(id, condition = 100) {
        this.id = id;
        this.def = ITEMS_DB[id];
        if (!this.def) { console.error(`Missing item: ${id}`); this.def = ITEMS_DB['scrap_metal']; }
        this.uuid = Math.random().toString(36).substr(2, 9);
        this.condition = condition;
        this.parts = {};
        this.gridX = 0; this.gridY = 0;
        this.rotated = false;
        
        if (this.def.type === ITEM_TYPES.WEAPON) this.barrelCondition = Math.max(10, condition); 
        if (this.def.type === ITEM_TYPES.PART && this.def.partType === PARTS.MAG) this.ammoCount = 0;
        // NEW: Initialize ammo stacks
        if (this.def.type === ITEM_TYPES.AMMO) this.ammoCount = 60;
    }
    
    get w() { return this.rotated ? this.def.h : this.def.w; }
    get h() { return this.rotated ? this.def.w : this.def.h; }
}

class Inventory {
    constructor(cols, rows) {
        this.cols = cols;
        this.rows = rows;
        this.items = [];
    }

    isFree(x, y, w, h) {
        if (x < 0 || y < 0 || x + w > this.cols || y + h > this.rows) return false;
        for (let i of this.items) {
            if (x < i.gridX + i.w && x + w > i.gridX && y < i.gridY + i.h && y + h > i.gridY) return false;
        }
        return true;
    }

    findSpot(w, h) {
        for (let y = 0; y <= this.rows - h; y++) {
            for (let x = 0; x <= this.cols - w; x++) {
                if (this.isFree(x, y, w, h)) return { x, y };
            }
        }
        return null;
    }

    add(item) {
        let spot = this.findSpot(item.w, item.h);
        if (spot) {
            item.gridX = spot.x;
            item.gridY = spot.y;
            this.items.push(item);
            return true;
        }
        return false;
    }
    
    rotate(item) {
        this.remove(item);
        item.rotated = !item.rotated;
        if (this.isFree(item.gridX, item.gridY, item.w, item.h)) {
            this.items.push(item);
            return true;
        }
        if (this.add(item)) return true;
        item.rotated = !item.rotated;
        this.items.push(item); 
        return false;
    }

    remove(item) {
        const idx = this.items.indexOf(item);
        if (idx > -1) {
            this.items.splice(idx, 1);
            return true;
        }
        return false;
    }
}

