<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Scavenger's Decay - Extraction Shooter</title>
    <style>
        :root {
            --bg-color: #0d0d0d;
            --ui-bg: rgba(15, 15, 15, 0.98);
            --ui-border: #555;
            --text-color: #dcdcdc;
            --accent: #e6b800;
            --danger: #d94343;
            --success: #4caf50;
            --extract: #00b7ff;
            --slot-size: 45px; 
        }
        body { margin: 0; overflow: hidden; background: var(--bg-color); font-family: 'Courier New', monospace; color: var(--text-color); user-select: none; }
        canvas { display: block; }
        
        /* UI Overlay */
        #ui-layer {
            position: absolute; top: 0; left: 0; width: 100%; height: 100%; pointer-events: none;
            display: flex; flex-direction: column; justify-content: space-between;
        }
        
        /* HUD */
        #hud { padding: 10px; pointer-events: auto; display: flex; gap: 20px; background: linear-gradient(to bottom, rgba(0,0,0,0.9), transparent); }
        .stat-box { display: flex; flex-direction: column; width: 100px; }
        .stat-label { font-size: 10px; color: #999; text-transform: uppercase; font-weight: bold; }
        .bar-container { width: 100%; height: 8px; background: #222; margin-top: 4px; border: 1px solid #444; box-shadow: 0 0 5px rgba(0,0,0,0.5); }
        .bar-fill { height: 100%; transition: width 0.2s; }
        
        #extract-msg {
            position: absolute; top: 20%; left: 50%; transform: translate(-50%, -50%);
            color: var(--extract); font-size: 24px; font-weight: bold; text-shadow: 0 0 10px var(--extract);
            display: none; animation: pulse 1s infinite;
        }
        @keyframes pulse { 0% { opacity:0.5; } 50% { opacity:1; } 100% { opacity:0.5; } }

        /* Action Bar */
        #action-bar-container {
            position: absolute; bottom: 30%; left: 50%; transform: translateX(-50%);
            width: 200px; height: 10px; background: #222; border: 1px solid #fff; display: none;
        }
        #action-bar-fill { height: 100%; background: var(--accent); width: 0%; transition: width 0.1s linear; }
        #action-label {
            position: absolute; bottom: 32%; left: 50%; transform: translateX(-50%);
            font-size: 12px; color: #fff; text-shadow: 1px 1px 0 #000; display: none;
        }

        /* Message Log */
        #log-container {
            position: absolute; bottom: 20px; left: 20px; width: 350px; height: 180px;
            overflow: hidden; pointer-events: none; text-shadow: 1px 1px 2px #000;
            background: linear-gradient(to top, rgba(0,0,0,0.8), transparent);
            padding: 10px; border-radius: 4px;
        }
        .log-entry { font-size: 13px; margin-bottom: 5px; opacity: 0.9; font-weight: bold; }

        /* SCALABLE MENU CONTAINER */
        #menu-overlay, #hideout-menu, #loot-menu {
            position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);
            width: 98vw; height: 90vh; 
            max-width: 1200px; max-height: 800px;
            background: var(--ui-bg); border: 1px solid var(--ui-border);
            display: none; pointer-events: auto; box-shadow: 0 0 50px rgba(0,0,0,0.8);
            flex-direction: row; border-radius: 4px;
            font-size: 12px;
        }
        
        .panel { 
            flex: 1; padding: 10px; 
            overflow: auto; 
            border-right: 1px solid #333; 
            display: flex; flex-direction: column; 
            min-width: 200px; 
        }
        .panel:last-child { border-right: none; }
        .scroll-content { overflow-y: auto; flex: 1; }
        
        h2 { margin-top: 0; border-bottom: 1px solid var(--accent); padding-bottom: 5px; font-size: 16px; color: var(--accent); letter-spacing: 1px; display: flex; justify-content: space-between; }
        
        /* Filters */
        .filter-bar { margin-bottom: 5px; display: flex; flex-wrap: wrap; gap: 2px; }
        .filter-btn {
            background: #222; border: 1px solid #444; color: #888; padding: 3px 6px; 
            font-size: 10px; cursor: pointer; flex: 1; text-align: center;
        }
        .filter-btn:hover { background: #333; color: #fff; }
        .filter-btn.active { background: #444; color: var(--accent); border-color: var(--accent); }

        /* Main Menu */
        #main-menu {
            position: absolute; top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0,0,0,0.9);
            display: flex; flex-direction: column; align-items: center; justify-content: center;
            pointer-events: auto; z-index: 100;
        }
        .menu-title { font-size: 48px; color: var(--text-color); margin-bottom: 40px; text-shadow: 0 0 10px var(--accent); letter-spacing: 5px; text-align: center;}
        .menu-btn {
            background: transparent; border: 2px solid #555; color: #aaa;
            padding: 15px 40px; margin: 10px; font-size: 18px; cursor: pointer;
            width: 250px; text-align: center; transition: 0.3s; letter-spacing: 2px;
        }
        .menu-btn:hover { border-color: var(--accent); color: #fff; background: rgba(230, 184, 0, 0.1); }
        .menu-btn:active { background: var(--accent); color: #000; }
        
        /* GRID SYSTEM */
        .inv-grid {
            position: relative; background: #222; border: 1px solid #444; margin: 0 auto;
            background-image: 
                linear-gradient(#333 1px, transparent 1px),
                linear-gradient(90deg, #333 1px, transparent 1px);
            background-size: var(--slot-size) var(--slot-size);
        }
        
        .grid-item {
            position: absolute; background: #3a3a3a; border: 1px solid #666;
            cursor: pointer; box-sizing: border-box; display: flex; flex-direction: column;
            justify-content: center; align-items: center; font-size: 10px; text-align: center;
            overflow: hidden; z-index: 10; transition: transform 0.1s, border-color 0.1s;
            box-shadow: 2px 2px 5px rgba(0,0,0,0.5);
        }
        .grid-item:hover { border-color: #fff; transform: scale(1.02); z-index: 11; }
        .grid-item.selected { border: 2px solid var(--accent); background: #444; z-index: 12; }
        .grid-item-icon { font-size: 18px; margin-bottom: 2px; }
        .grid-item-name { font-size: 9px; line-height: 1; pointer-events: none; }
        .grid-item-meta { position: absolute; bottom: 1px; right: 1px; font-size: 8px; color: #aaa; background: rgba(0,0,0,0.8); padding: 1px 2px; border-radius: 2px; }

        /* Item Type Colors */
        .type-weapon { background: #3a2a2a; border-left: 2px solid #d94343; }
        .type-armor { background: #2a2a3a; border-left: 2px solid #4363d9; }
        .type-medical { background: #2a3a2a; border-left: 2px solid #4caf50; }
        .type-food { background: #3a3a2a; border-left: 2px solid #e6b800; }
        .type-part { background: #252525; border-left: 2px solid #888; }

        /* Character Slots */
        #gear-slots { display: flex; flex-direction: column; gap: 5px; align-items: center; margin-bottom: 10px; }
        .gear-slot {
            width: 100%; height: 50px; border: 1px dashed #555; display: flex; flex-direction: column;
            justify-content: center; align-items: center; background: rgba(0,0,0,0.2); cursor: pointer;
            position: relative;
        }
        .gear-slot:hover { background: rgba(255,255,255,0.05); border-color: #888; }
        .gear-slot.equipped { border-style: solid; border-color: var(--accent); background: #1a1a1a; }
        .gear-label { font-size: 9px; color: #666; text-transform: uppercase; margin-bottom: 2px; }
        .gear-name { font-size: 11px; font-weight: bold; color: #ddd; text-align: center;}
        
        button {
            background: #2a2a2a; color: #ddd; border: 1px solid #444; padding: 6px 10px; cursor: pointer; font-family: inherit; margin: 2px;
            text-transform: uppercase; font-size: 10px; letter-spacing: 1px; transition: background 0.2s;
        }
        button:hover { background: #333; border-color: var(--accent); color: #fff; }
        
        /* Weapon/Armor Parts */
        #assembly-view { display: none; flex-direction: column; margin-top: 5px; border-top: 1px solid #333; padding-top: 5px; flex: 1; overflow-y: auto;}
        .part-slot { margin: 2px 0; padding: 6px; border: 1px dashed #444; text-align: center; font-size: 10px; cursor: pointer; }
        .part-slot.occupied { border-style: solid; border-color: #555; text-align: left; background: #1a1a1a; }
        
        .money-display { color: var(--success); font-weight: bold; font-size: 14px; }
        
        /* List items for stash list mode if needed, or shop */
        .item-slot {
            background: #222; border: 1px solid #333; margin-bottom: 2px; padding: 5px;
            cursor: pointer; display: flex; justify-content: space-between; align-items: center;
            transition: all 0.1s; font-size: 11px;
        }
        .item-slot:hover { background: #2a2a2a; border-color: var(--accent); }
        .item-slot.shop-item { border-left: 3px solid var(--accent); }
        .item-name { font-weight: bold; }
        .item-cost { color: var(--success); font-weight: bold; }

        .danger { color: #ff5555; }
        .good { color: #55ff55; }
    </style>
</head>
<body>

<canvas id="gameCanvas"></canvas>

<!-- IN-GAME HUD -->
<div id="ui-layer" style="display:none">
    <div id="extract-msg">PRESS [F] TO EXTRACT</div>
    <div id="action-label">Healing...</div>
    <div id="action-bar-container"><div id="action-bar-fill"></div></div>
    
    <div id="hud">
        <div class="stat-box"><span class="stat-label">Health</span><div class="bar-container"><div id="bar-hp" class="bar-fill" style="background:#b93b3b; width:100%"></div></div></div>
        <div class="stat-box"><span class="stat-label">Hunger</span><div class="bar-container"><div id="bar-hunger" class="bar-fill" style="background:#d4a017; width:100%"></div></div></div>
        <div class="stat-box"><span class="stat-label">Thirst</span><div class="bar-container"><div id="bar-thirst" class="bar-fill" style="background:#3b8bb9; width:100%"></div></div></div>
        <div class="stat-box"><span class="stat-label">Stamina</span><div class="bar-container"><div id="bar-stamina" class="bar-fill" style="background:#cfcfcf; width:100%"></div></div></div>
    </div>
    <div id="log-container"></div>
</div>

<!-- MAIN MENU -->
<div id="main-menu">
    <div class="menu-title">SCAVENGER'S DECAY</div>
    <div class="menu-btn" onclick="Game.deploy()">DEPLOY TO RAID</div>
    <div class="menu-btn" onclick="Hideout.open()">HIDEOUT</div>
    <div class="menu-btn" onclick="Game.resetGame()" style="border-color: #933; color:#a66; margin-top:40px; font-size:12px; padding:10px;">RESET PROFILE</div>
    <div style="margin-top:20px; color:#666; font-size:12px">Extraction Shooter Mode</div>
</div>

<!-- HIDEOUT / STASH / SHOP -->
<div id="hideout-menu">
    <!-- Stash Grid -->
    <div class="panel" style="flex:1.5;">
        <h2>STASH <span class="money-display">§<span id="stash-money">0</span></span></h2>
        <div style="margin-bottom:10px;">
            <button onclick="Hideout.toggleShop()" id="btn-shop-toggle">OPEN SHOP</button>
            <button onclick="Hideout.close()">MAIN MENU</button>
        </div>
        <div id="stash-grid-container" class="scroll-content"></div>
    </div>
    <!-- Middle: Character -->
    <div class="panel">
        <h2>CHARACTER</h2>
        <div id="hideout-gear-slots"></div>
        <div style="margin-top:auto; font-size:10px; color:#666; text-align:center;">Click item to inspect/equip.<br>Rotate via inspection.</div>
    </div>
    <!-- Right: Backpack Grid -->
    <div class="panel">
        <h2>BACKPACK</h2>
        <div id="hideout-backpack-container"></div>
    </div>
</div>

<!-- LOOTING UI -->
<div id="loot-menu">
    <div class="panel" style="flex:1.5;">
        <h2><span id="loot-title">CONTAINER</span></h2>
        <div id="loot-container-grid"></div>
        <button style="margin-top:10px; width:100%" onclick="LootUI.takeAll()">TAKE ALL</button>
    </div>
    <div class="panel">
        <h2>BACKPACK</h2>
        <div id="loot-backpack-grid"></div>
        <div style="margin-top:20px; color:#666; font-size:11px; text-align:center">
            Click to transfer.
        </div>
        <button style="margin-top:auto; width:100%" onclick="LootUI.close()">CLOSE</button>
    </div>
</div>

<!-- IN-GAME INVENTORY -->
<div id="menu-overlay">
    <!-- Left: Inventory Grid -->
    <div class="panel" id="panel-inventory" style="flex:1.2;">
        <h2>Backpack</h2>
        <div id="ingame-backpack-grid"></div>
    </div>
    
    <!-- Middle: Character -->
    <div class="panel" id="panel-character">
        <h2>CHARACTER</h2>
        <div id="gear-slots-ingame"></div>
        <div style="margin-top:10px; border-top:1px solid #333; padding-top:5px;">
            <div class="stat-label">Weapon Stats</div>
            <div id="char-weapon-stats" style="font-size:11px; color:#aaa;">No Weapon</div>
        </div>
    </div>

    <!-- Right: Status (Top) & Inspection (Bottom) -->
    <div class="panel" id="panel-right">
        <div style="height:35%; padding-bottom:5px; border-bottom:1px solid #333; min-height: 150px;">
            <h2>Status</h2>
            <div style="background:#111; padding:10px; border:1px solid #333; font-size:11px; line-height:1.4; color:#bbb;">
                Temp: <span id="val-temp" style="color:#fff">20°C</span><br>
                Blood: <span id="val-blood" style="color:#fff">5.0L</span><br>
                State: <span id="val-status">Healthy</span>
            </div>
            <div style="margin-top:5px; font-size: 10px; color:#666;">
                [E] Loot &nbsp; [F] Extract &nbsp; [L] Light<br>
                [TAB] Inv &nbsp; [R] Reload
            </div>
            <button onclick="Game.exitRaid(false)" style="margin-top:5px; width:100%; border-color:#933; color:#a66;">ABORT RAID</button>
        </div>
        
        <div style="flex:1; display:flex; flex-direction:column; padding-top:5px; overflow:hidden;">
            <h2>Inspection</h2>
            <div id="item-details-content" style="color:#666; font-style:italic;">Select an item...</div>
            <div id="context-actions" style="display:flex; flex-wrap:wrap;"></div>
            <div id="assembly-view">
                <h3 style="font-size:11px; color:var(--accent); margin-bottom:5px;">COMPONENTS</h3>
                <div id="parts-container"></div>
            </div>
        </div>
    </div>
</div>

